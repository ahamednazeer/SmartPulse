# Frontend runtime
NEXT_PUBLIC_API_URL=http://localhost:3001/api
# If frontend runs over HTTPS, set an HTTPS API URL:
# NEXT_PUBLIC_API_URL=https://localhost:3001/api

# Optional native/mobile override (Capacitor Android/iOS)
# Use your machine LAN address so device/emulator can reach backend.
# Example:
# NEXT_PUBLIC_API_URL_MOBILE=http://192.168.1.21:3001/api
NEXT_PUBLIC_API_URL_MOBILE=
