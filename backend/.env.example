# Backend runtime
NODE_ENV=development
PORT=3001
CORS_ORIGIN=http://localhost:3000,http://127.0.0.1:3000,https://localhost:3000,https://127.0.0.1:3000,http://localhost,https://localhost,capacitor://localhost
HOST=0.0.0.0

# Auth
JWT_SECRET=change-this-in-production

# Optional HTTPS backend (required if frontend is served over HTTPS and calls backend directly)
HTTPS_KEY_PATH=
HTTPS_CERT_PATH=

# Groq AI (optional)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_TIMEOUT_MS=1800
